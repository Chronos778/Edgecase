# Edgecase Environment Configuration - Production
# Copy this file to .env and fill in your actual values
# For development, use localhost values. For production, use managed services.

# ============================================================================
# DATABASE - Use Neon for production (https://neon.tech/)
# For dev: use localhost postgres
# ============================================================================
# Production (Neon):
# DATABASE_URL=postgresql://user:password@ep-host.neon.tech/edgecase?sslmode=require
# Dev (local):
DATABASE_URL=postgresql://edgecase:edgecase_secret@localhost:5432/edgecase
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edgecase
POSTGRES_USER=edgecase
POSTGRES_PASSWORD=edgecase_secret

# ============================================================================
# GRAPH DB - Use Neo4j Aura for production (https://neo4j.com/cloud/aura/)
# For dev: use localhost
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=edgecase_secret

# ============================================================================
# VECTOR DB - Use Qdrant Cloud for production (https://qdrant.tech/cloud/)
# For dev: use localhost
# ============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
# For Qdrant Cloud:
# QDRANT_HOST=your-cluster-id.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ============================================================================
# CACHE - Use Upstash Redis for production (https://upstash.com/)
# For dev: use localhost
# ============================================================================
REDIS_URL=redis://localhost:6379
# For Upstash:
# REDIS_URL=redis://default:password@host.upstash.io:port

# ============================================================================
# LLM SERVICES
# ============================================================================
# NVIDIA API (required)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================================================
# WEATHER (Open-Meteo - free, no key needed)
# ============================================================================
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ============================================================================
# APPLICATION CONFIG
# ============================================================================
APP_NAME=Edgecase
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Frontend URL (for CORS)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# SCRAPING CONFIGURATION
# ============================================================================
SCRAPING_THREADS=4
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
FEED_POLL_INTERVAL=5
SCRAPER_TIMEOUT=30

# ============================================================================
# SOCIAL MEDIA (optional)
# ============================================================================
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_secret
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token
